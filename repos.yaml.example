workspace: ./repos           # directory where repos will be placed

# Default behavior for `xr repo sync`. Each field is optional. CLI flags on the
# sync command override these, and a per-repository `sync:` block (see below)
# overrides this global section.
sync:
  fetch: true
  pull: true
  prune: false
  submodules: false

repositories:
  - name: project-a
    source: git@github.com:user/project-a.git
    branch: main
    path: project-a          # relative path within workspace

  - name: project-b
    source: git@github.com:user/project-b.git
    branch: develop
    path: project-b
    sync:                    # per-repo override: don't pull this repo
      pull: false

  - name: local-lib
    source: /path/to/local-lib  # local path -> symlink
    type: symlink
    path: local-lib
